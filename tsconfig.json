
{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "typeRoots": ["./types", "./node_modules/@types"],
    "paths": {
      "@/*": ["./*"],
      "@db/*": ["./db/*"],
      "@server/*": ["./server/*"]
    }
  },
  "include": ["server/**/*", "db/**/*", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "tmp", "client"]
}
