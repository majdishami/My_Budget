{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "typeRoots": ["./types", "./node_modules/@types"],
    "paths": {
      "@db/*": ["db/*"]
    }
  },
  "include": ["src/**/*.ts", "sequelize.js", "models/**/*.js", "index.js"],
  "exclude": ["node_modules", "dist"]
}