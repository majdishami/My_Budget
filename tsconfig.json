{
  "compilerOptions": {
    "baseUrl": ".",  // Set to the root of the project
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": ".",  // Updated to the root of the project
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "typeRoots": ["./types", "./node_modules/@types"],
    "paths": {
      "@db/*": ["server/db/*"]  // Added path mapping
    }
  },
  "include": ["server/**/*", "vite.config.ts"],  // Updated include paths
  "exclude": ["node_modules", "dist", "tmp"]  // Updated exclude paths
}